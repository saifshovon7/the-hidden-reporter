# ============================================================
# The Hidden Reporter — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Public/anon key — safe to expose in HTML (used for client-side view tracking)
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- AI API (OpenAI-compatible: OpenAI, Groq, etc.) ---
AI_API_KEY=your-api-key
AI_MODEL=llama-3.1-8b-instant
# For Groq: https://api.groq.com/openai/v1
# For OpenAI: https://api.openai.com/v1
AI_BASE_URL=https://api.groq.com/openai/v1

# --- GitHub ---
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=the-hidden-reporter
GITHUB_BRANCH=main

# --- Optional: NewsAPI ---
# Get a free key at https://newsapi.org
NEWS_API_KEY=

# --- Optional: GDELT API (no key needed) ---
USE_GDELT=false

# --- Site Configuration ---
SITE_URL=https://thehiddenreporter.pages.dev
SITE_NAME=The Hidden Reporter

# --- Publishing Limits ---
MAX_ARTICLES_PER_DAY=30
FETCH_INTERVAL_MINUTES=45
# Minutes to wait between publishing each article (prevents GitHub/Cloudflare deployment flooding)
POST_PUBLISH_DELAY_MINUTES=5
